{
  "name": "tsu/ict-complaint",
  "description": "TSU ICT Complaint Help Desk System",
  "type": "project",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-strict-rules": "^1.5",
    "spaze/phpstan-disallowed-calls": "^3.0",
    "vimeo/psalm": "^5.0",
    "roave/security-advisories": "dev-latest"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "roave/security-advisories": true
    }
  }
}
