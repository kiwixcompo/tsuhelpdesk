APP_NAME="TSU ICT Help Desk"
APP_ENV=production
APP_URL=https://helpdesk.tsuniversity.ng
APP_DEBUG=false

# Database Connectivity
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=tsuniver_tsu_ict_complaints
DB_USERNAME=tsuniver_tsu_ict_complaints
# Set DB_PASSWORD to a cryptographically secure, randomized string in production
DB_PASSWORD=""

# SMTP Mail Server Integration (e.g., SendGrid, Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=complaints@tsuniversity.edu.ng
# Avoid committing real email passwords; store them only in target system's local .env
MAIL_PASSWORD=""
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=complaints@tsuniversity.edu.ng
MAIL_FROM_NAME="TSU ICT Help Desk"

# Secure Session Management
SESSION_LIFETIME=120
